import numpy as np
import pandas as pd
import matplotlib.pyplot as plt
import seaborn as sns
from sklearn.model_selection import train_test_split, cross_val_score, StratifiedKFold
from sklearn.preprocessing import StandardScaler
from sklearn.linear_model import LogisticRegression
from sklearn.metrics import (accuracy_score, confusion_matrix, classification_report,
                             roc_auc_score, roc_curve)
import warnings
warnings.filterwarnings('ignore')

# Visualization settings
plt.style.use('seaborn-v0_8-darkgrid')
sns.set_palette("husl")

class CancerPresenceClassifier:
    """
    Binary classifier for cancer presence detection using Logistic Regression.
    Predicts whether cancer is present (1) or not (0).
    """
    
    def __init__(self, random_state=45, test_size=0.2):
        self.random_state = random_state
        self.test_size = test_size
        self.scaler = StandardScaler()
        self.model = None
        self.X_train = None
        self.X_test = None
        self.y_train = None
        self.y_test = None
        
    def load_and_explore_data(self, filepath):
        #load dataset and perform initial exploratory analysis
        print("="*60)
        print("DATA LOADING & EXPLORATION")
        print("="*60)
        
        # Load data
        self.df = pd.read_csv(filepath)
        
        # Basic information
        print(f"\nDataset shape: {self.df.shape}")
        print(f"\nFeatures: {self.df.columns.tolist()}")
        print(f"\nTarget distribution (0 = no cancer, 1 = cancer present):")
        print(self.df['diagnosis'].value_counts())
        print(f"\nMissing values:\n{self.df.isnull().sum()}")
        
        return self.df
    
    def visualize_correlation(self):
        #visualize correlation matrix
        plt.figure(figsize=(14, 10))
        
        # Correlation heatmap
        corrmat = self.df.corr()
        mask = np.triu(np.ones_like(corrmat, dtype=bool))
        sns.heatmap(corrmat, mask=mask, annot=False, fmt='.2f', 
                   cmap='coolwarm', center=0, square=True, 
                   linewidths=0.5, cbar_kws={"shrink": 0.8})
        plt.title('Feature Correlation Matrix', fontsize=16, pad=20)
        plt.tight_layout()
        plt.show()
        
        # Top features correlated with cancer presence
        print("\n" + "="*60)
        print("TOP 6 FEATURES CORRELATED WITH CANCER PRESENCE")
        print("="*60)
        correlations = self.df.corr()['diagnosis'].sort_values(ascending=False)
        top_features = correlations[1:7]
        for feature, corr in top_features.items():
            print(f"{feature}: {corr:.4f}")
            
        return top_features
    
    def preprocess_data(self, drop_highly_correlated=True):
        #preprocess data by removing highly correlated features
        print("\n" + "="*60)
        print("DATA PREPROCESSING")
        print("="*60)
        
        # Remove highly correlated features to reduce multicollinearity
        if drop_highly_correlated:
            correlations = self.df.corr()
            high_corr_pairs = []
            
            for i in range(len(correlations.columns)):
                for j in range(i+1, len(correlations.columns)):
                    if abs(correlations.iloc[i, j]) > 0.95:
                        high_corr_pairs.append((correlations.columns[i], 
                                               correlations.columns[j], 
                                               correlations.iloc[i, j]))
            
            if high_corr_pairs:
                print("\nHighly correlated features (>0.95):")
                for pair in high_corr_pairs:
                    print(f"  {pair[0]} - {pair[1]}: {pair[2]:.4f}")
                
                # Drop redundant features
                features_to_drop = ['mean_radius', 'mean_area']
                features_to_drop = [f for f in features_to_drop if f in self.df.columns]
                
                if features_to_drop:
                    self.df.drop(columns=features_to_drop, inplace=True)
                    print(f"\nDropped features: {features_to_drop}")
        
        # Split features and target
        self.X = self.df.drop(columns=['diagnosis'])
        self.y = self.df['diagnosis']
        
        print(f"\nFeatures after preprocessing: {self.X.shape[1]}")
        print(f"Samples: {self.X.shape[0]}")
        
        return self.X, self.y
    
    def split_and_scale_data(self):
        # Split data into train/test sets and apply standardization
        print("\n" + "="*60)
        print("DATA SPLITTING & SCALING")
        print("="*60)
        
        # Split data
        self.X_train, self.X_test, self.y_train, self.y_test = train_test_split(
            self.X, self.y, test_size=self.test_size, 
            random_state=self.random_state, stratify=self.y
        )
        
        print(f"Training set: {self.X_train.shape[0]} samples")
        print(f"Test set: {self.X_test.shape[0]} samples")
        print(f"\nTraining set distribution:")
        print(f"  No cancer (0): {(self.y_train == 0).sum()} samples")
        print(f"  Cancer present (1): {(self.y_train == 1).sum()} samples")
        
        # Standardize features
        self.scaler.fit(self.X_train)
        self.X_train_scaled = self.scaler.transform(self.X_train)
        self.X_test_scaled = self.scaler.transform(self.X_test)
        
        print(f"\nFeature scaling completed")
        
        return self.X_train_scaled, self.X_test_scaled, self.y_train, self.y_test
    
    def train_model(self, C=1.0, penalty='l2', solver='lbfgs', max_iter=1000):
        # Train logistic regression model
        print("\n" + "="*60)
        print("MODEL TRAINING")
        print("="*60)
        
        # Initialize model
        self.model = LogisticRegression(
            C=C,
            penalty=penalty,
            solver=solver,
            max_iter=max_iter,
            random_state=self.random_state,
            class_weight='balanced'
        )
        
        # Train
        self.model.fit(self.X_train_scaled, self.y_train)
        
        # Display coefficients
        print(f"\nModel coefficients:")
        coefficients = pd.DataFrame({
            'feature': self.X.columns,
            'coefficient': self.model.coef_[0],
            'abs_coefficient': np.abs(self.model.coef_[0])
        }).sort_values('abs_coefficient', ascending=False)
        print(coefficients.head(10))
        print(f"\nIntercept: {self.model.intercept_[0]:.4f}")
        
        return self.model
    
    def evaluate_model(self):
        # Evaluate model performance
        print("\n" + "="*60)
        print("MODEL EVALUATION")
        print("="*60)
        
        # Predictions
        y_pred_proba = self.model.predict_proba(self.X_test_scaled)
        y_pred = self.model.predict(self.X_test_scaled)
        
        # Metrics
        accuracy = accuracy_score(self.y_test, y_pred)
        roc_auc = roc_auc_score(self.y_test, y_pred_proba[:, 1])
        
        print(f"\nAccuracy: {accuracy:.4f}")
        print(f"ROC-AUC: {roc_auc:.4f}")
        
        # Confusion Matrix
        cm = confusion_matrix(self.y_test, y_pred)
        print(f"\nConfusion Matrix:")
        print(pd.DataFrame(cm, 
                          index=['Actual: No Cancer', 'Actual: Cancer'], 
                          columns=['Predicted: No Cancer', 'Predicted: Cancer']))
        
        # Classification Report
        print(f"\nClassification Report:")
        print(classification_report(self.y_test, y_pred, 
                                   target_names=['No Cancer', 'Cancer Present']))
        
        # Cross-validation
        cv = StratifiedKFold(n_splits=5, shuffle=True, random_state=self.random_state)
        cv_scores = cross_val_score(self.model, self.X_train_scaled, self.y_train, 
                                    cv=cv, scoring='accuracy')
        print(f"\n5-Fold Cross-Validation Scores:")
        print(f"  Mean: {cv_scores.mean():.4f} (+/- {cv_scores.std()*2:.4f})")
        print(f"  Individual: {cv_scores}")
        
        return {
            'accuracy': accuracy,
            'roc_auc': roc_auc,
            'confusion_matrix': cm,
            'cv_scores': cv_scores
        }
    
    def visualize_results(self):
        # Visualize model results
        fig, axes = plt.subplots(2, 2, figsize=(14, 10))
        
        # 1. ROC Curve
        y_pred_proba = self.model.predict_proba(self.X_test_scaled)[:, 1]
        fpr, tpr, _ = roc_curve(self.y_test, y_pred_proba)
        roc_auc = roc_auc_score(self.y_test, y_pred_proba)
        
        axes[0, 0].plot(fpr, tpr, color='darkorange', lw=2, 
                        label=f'ROC curve (AUC = {roc_auc:.4f})')
        axes[0, 0].plot([0, 1], [0, 1], color='navy', lw=2, linestyle='--')
        axes[0, 0].set_xlim([0.0, 1.0])
        axes[0, 0].set_ylim([0.0, 1.05])
        axes[0, 0].set_xlabel('False Positive Rate')
        axes[0, 0].set_ylabel('True Positive Rate')
        axes[0, 0].set_title('ROC Curve - Cancer Detection')
        axes[0, 0].legend(loc="lower right")
        axes[0, 0].grid(True, alpha=0.3)
        
        # 2. Confusion Matrix
        y_pred = self.model.predict(self.X_test_scaled)
        cm = confusion_matrix(self.y_test, y_pred)
        sns.heatmap(cm, annot=True, fmt='d', cmap='Blues', ax=axes[0, 1],
                   xticklabels=['No Cancer', 'Cancer'],
                   yticklabels=['No Cancer', 'Cancer'])
        axes[0, 1].set_title('Confusion Matrix')
        axes[0, 1].set_xlabel('Predicted')
        axes[0, 1].set_ylabel('Actual')
        
        # 3. Feature Importance
        coefficients = np.abs(self.model.coef_[0])
        feature_importance = pd.DataFrame({
            'feature': self.X.columns,
            'importance': coefficients
        }).sort_values('importance', ascending=True).tail(10)
        
        axes[1, 0].barh(feature_importance['feature'], feature_importance['importance'])
        axes[1, 0].set_xlabel('Absolute Coefficient Value')
        axes[1, 0].set_title('Top 10 Most Important Features')
        axes[1, 0].grid(True, alpha=0.3, axis='x')
        
        # 4. Prediction Probability Distribution
        axes[1, 1].hist(y_pred_proba[self.y_test == 0], bins=20, alpha=0.7, 
                        label='No Cancer', color='green')
        axes[1, 1].hist(y_pred_proba[self.y_test == 1], bins=20, alpha=0.7, 
                        label='Cancer Present', color='red')
        axes[1, 1].set_xlabel('Probability of Cancer')
        axes[1, 1].set_ylabel('Frequency')
        axes[1, 1].set_title('Prediction Probability Distribution')
        axes[1, 1].legend()
        axes[1, 1].grid(True, alpha=0.3)
        
        plt.tight_layout()
        plt.show()
        
        return fig


def main():
    # Main function to execute the pipeline
    print("="*60)
    print("BREAST CANCER DETECTION WITH LOGISTIC REGRESSION")
    print("="*60)
    
    # Initialize classifier
    classifier = CancerPresenceClassifier(random_state=45, test_size=0.2)
    
    # Load and analyze data
    try:
        df = classifier.load_and_explore_data("Breast_cancer_data.csv")
    except FileNotFoundError:
        print("Error: Data file not found. Please check the file path.")
        return
    
    # Visualize correlations
    top_features = classifier.visualize_correlation()
    
    # Preprocess data
    X, y = classifier.preprocess_data(drop_highly_correlated=True)
    
    # Split and scale
    X_train_scaled, X_test_scaled, y_train, y_test = classifier.split_and_scale_data()
    
    # Train model
    model = classifier.train_model(C=1.0, penalty='l2', solver='lbfgs', max_iter=1000)
    
    # Evaluate model
    metrics = classifier.evaluate_model()
    
    # Visualize results
    classifier.visualize_results()
    
    print("\n" + "="*60)
    print("PIPELINE COMPLETED SUCCESSFULLY")
    print("="*60)


if __name__ == "__main__":
    main()
